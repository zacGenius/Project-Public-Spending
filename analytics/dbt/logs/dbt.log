  create  table "public_spend"."gold_gold"."dim_orgaos__dbt_tmp"
  
  
    as
  
  (
    SELECT
    
    upper(
        trim(
            regexp_replace(orgao, '\s+', ' ', 'g')
            -- remove espaços duplos, tabs, etc
        )
    )
 AS orgao,
    orgao_superior,
    COUNT(DISTINCT ano) AS anos_com_dados,
    MIN(ano) AS primeiro_ano,
    MAX(ano) AS ultimo_ano,
    SUM(pago) AS total_historico
FROM "public_spend"."gold_intermediate"."int_gastos_normalizado"
GROUP BY 1, 2
ORDER BY total_historico DESC
  );
  
